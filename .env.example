# ── Database ────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/docai
POSTGRES_PASSWORD=postgres

# ── LLM Backend ─────────────────────────────────────────────────
# "local" uses Qwen3-8B on GPU | "groq" uses Groq cloud API
LLM_BACKEND=local
LLM_MODEL=Qwen/Qwen3-8B

# Groq (only needed if LLM_BACKEND=groq)
GROQ_API_KEY=
GROQ_MODEL=llama3-8b-8192

# ── Embedding ───────────────────────────────────────────────────
EMBED_MODEL=BAAI/bge-m3

# ── RAG ─────────────────────────────────────────────────────────
MAX_NEW_TOKENS=512
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=3
MEMORY_WINDOW=5

# ── Auth ────────────────────────────────────────────────────────
ADMIN_KEY=change-me-in-production

# ── n8n ─────────────────────────────────────────────────────────
N8N_PASSWORD=change-me-in-production

# ── Webhooks ────────────────────────────────────────────────────
WEBHOOK_TIMEOUT=5.0
