# LLM local (downloaded from HuggingFace on first run, requires ~16GB VRAM)
LLM_MODEL=Qwen/Qwen3-8B

# Embedding model (local, requires ~2GB RAM)
EMBED_MODEL=BAAI/bge-m3

# Generation
MAX_NEW_TOKENS=512

# Chunking
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=3

# API server
API_HOST=localhost
API_PORT=8000

# URL the Streamlit UI calls (set to public URL in production)
API_URL=http://localhost:8000

# Admin
ADMIN_KEY=change-me-in-production
